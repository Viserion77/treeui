{
  "name": "treeui",
  "version": "0.1.0",
  "private": true,
  "description": "Clean components for modern Vue products.",
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "vue": "$vue"
    }
  },
  "scripts": {
    "clean": "pnpm -w exec rimraf coverage playwright-report test-results apps/docs/storybook-static \"packages/*/dist\"",
    "dev": "pnpm docs:dev",
    "docs:dev": "pnpm build:packages && pnpm --filter @treeui/docs docs:dev",
    "build:docs": "pnpm --filter @treeui/docs docs:build",
    "build:docs:react": "pnpm --filter @treeui/docs-react docs:build",
    "build:landing": "pnpm --filter @treeui/landing build",
    "docs:build": "pnpm build:packages && pnpm build:docs",
    "build:site": "pnpm build:packages && pnpm build:landing && pnpm build:docs && pnpm build:docs:react && node scripts/assemble-site.mjs",
    "docs:serve": "node scripts/serve-static.mjs apps/docs/storybook-static 6006 0.0.0.0",
    "docs:serve:ci": "node scripts/serve-static.mjs apps/docs/storybook-static 6006 127.0.0.1",
    "site:serve": "node scripts/serve-static.mjs site 6010 0.0.0.0",
    "ai:catalog": "pnpm --filter @treeui/mcp generate:catalog",
    "mcp:test": "pnpm --filter @treeui/mcp test",
    "mcp:start": "pnpm --filter @treeui/mcp start",
    "build:packages": "pnpm --filter @treeui/tokens build && pnpm --filter @treeui/utils build && pnpm --filter @treeui/icons build && pnpm --filter @treeui/vue build && pnpm --filter @treeui/react build && pnpm --filter @treeui/mcp build",
    "build": "pnpm docs:build",
    "lint": "pnpm -w exec eslint . --max-warnings 0",
    "typecheck": "pnpm --filter @treeui/tokens typecheck && pnpm --filter @treeui/utils typecheck && pnpm --filter @treeui/icons typecheck && pnpm --filter @treeui/vue typecheck && pnpm --filter @treeui/react typecheck && pnpm --filter @treeui/mcp typecheck && pnpm --filter @treeui/docs typecheck && pnpm --filter @treeui/docs-react typecheck && pnpm --filter @treeui/landing typecheck",
    "test": "pnpm -w exec vitest run --coverage",
    "test:e2e": "pnpm -w exec playwright test",
    "screenshots": "pnpm -w exec tsx scripts/screenshot-components.ts",
    "screenshots:only": "pnpm -w exec tsx scripts/screenshot-components.ts --skip-build",
    "render:logos": "node scripts/render-logos.mjs",
    "changeset": "pnpm -w exec changeset",
    "version-packages": "pnpm -w exec changeset version",
    "release": "pnpm build:packages && pnpm -w exec changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.61.1",
    "@resvg/resvg-js": "^2.6.2",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.15.0",
    "http-server": "^14.1.1",
    "jsdom": "^26.0.0",
    "prettier": "^3.9.4",
    "rimraf": "^6.0.1",
    "storybook": "^10.4.6",
    "tsup": "^8.4.0",
    "tsx": "^4.22.5",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.6",
    "vue": "^3.5.34",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.4"
  }
}

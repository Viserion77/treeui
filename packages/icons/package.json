{
  "name": "@treeui/icons",
  "version": "0.1.1",
  "description": "Lucide-backed icon defaults and registry for TreeUI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec rimraf dist && pnpm exec tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  }
}

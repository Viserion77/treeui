{
  "name": "@treeui/tokens",
  "version": "0.1.0",
  "description": "Framework-agnostic design tokens and themes for TreeUI.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./themes.css": "./dist/themes.css",
    "./light.css": "./dist/light.css",
    "./dark.css": "./dist/dark.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec rimraf dist && pnpm exec tsup src/index.ts --format esm,cjs --dts --clean false && pnpm exec tsx src/build-css.ts",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit"
  }
}

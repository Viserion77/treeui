{
  "name": "@treeui/vue",
  "version": "0.1.0",
  "description": "Vue 3 component package for TreeUI.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm exec rimraf dist && pnpm exec vite build",
    "typecheck": "pnpm exec vue-tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@treeui/icons": "workspace:*",
    "@treeui/tokens": "workspace:*",
    "@treeui/utils": "workspace:*"
  }
}
